<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ActMain" >

    <ImageButton
        android:id="@+id/btnProj"
        android:layout_width="fill_parent"
        android:layout_height="match_parent"
        android:layout_weight="0.5"
        android:layout_margin="5dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/projects"
        app:srcCompat="@drawable/projects" />

    <ImageButton
        android:id="@+id/btnStu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="0.5"
        android:layout_margin="5dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/studies"
        app:srcCompat="@drawable/studies" />

</LinearLayout>